{
  "name": "01-gate",
  "version": "0.1.0",
  "description": "01门 - Decentralized micro-task network with AI agents as demand side",
  "main": "src/index.js",
  "bin": {
    "01-gate": "./bin/cli.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "cli": "node bin/cli.js",
    "init": "node bin/cli.js init",
    "status": "node bin/cli.js status",
    "task": "node bin/cli.js create-task",
    "test": "node test/test.js",
    "dev": "nodemon src/index.js",
    "api": "node src/adapter/APIAdapter.js",
    "serve": "node -e \"const {quickStart}=require('./src/adapter/APIAdapter.js'); quickStart()\""
  },
  "keywords": [
    "blockchain",
    "p2p",
    "task",
    "decentralized",
    "ai",
    "agent",
    "microwork",
    "freelance"
  ],
  "author": "01men",
  "license": "MIT",
  "homepage": "https://github.com/01men/01-gate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/01men/01-gate.git"
  },
  "bugs": {
    "url": "https://github.com/01men/01-gate/issues"
  },
  "dependencies": {
    "ethers": "^6.11.0",
    "uuid": "^9.0.0",
    "express": "^4.18.2",
    "crypto-js": "^4.2.0",
    "libp2p": "^1.2.0",
    "libp2p-tcp": "^0.17.2",
    "libp2p-websockets": "^0.16.2",
    "libp2p-mplex": "^0.10.7",
    "libp2p-noise": "^4.0.6",
    "libp2p-kad-dht": "^1.0.9",
    "libp2p-gossipsub": "^1.2.0",
    "multiaddr": "^10.0.1",
    "uint8arrays": "^3.1.0"
  },
  "devDependencies": {}
}
